{
  "name": "slack-bot",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:slack": "dotenv -e ../../.env -- vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@linkdigest/shared": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@slack/bolt": "^4.3.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@slack/web-api": "^7.15.0",
    "@types/node": "^22.15.3",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
